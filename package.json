{
  "name": "cmux-open-file",
  "version": "0.2.4",
  "description": "Open files in cmux via a fuzzy '@' picker in fish shell",
  "type": "module",
  "bin": {
    "cmux-open-file": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --minify && bun build src/postinstall.ts --outdir dist --target node",
    "test": "bun test",
    "prepublishOnly": "bun run build",
    "postinstall": "node ./dist/postinstall.js || true"
  },
  "dependencies": {
    "fdir": "^6.4.2",
    "fuzzysort": "^3.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryu1sazae/cmux-open-file.git"
  }
}
